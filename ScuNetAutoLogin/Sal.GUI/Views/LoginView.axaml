<UserControl
    x:Class="Sal.GUI.Views.LoginView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="clr-namespace:Sal.GUI.Resx"
    xmlns:vm="using:Sal.GUI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:LoginViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:LoginViewModel />
    </Design.DataContext>

    <DockPanel Margin="8">
        <StackPanel
            HorizontalAlignment="Center"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding LoginCommand}" Content="{x:Static res:ResUI.LbLogin}" />
            <Separator />
            <Button Command="{Binding OpenHotspotCommand}" Content="{x:Static res:ResUI.LbEnableHotspot}" />
            <Button Command="{Binding ConnectSCUNETWifiCommand}" Content="{x:Static res:ResUI.LbConnectWifi}" />
        </StackPanel>
        <StackPanel Orientation="Vertical" Spacing="8">
            <Border
                Margin="20"
                Padding="15"
                Background="{DynamicResource SystemRegionBrushLow}"
                BoxShadow="0 4 10 0 #40000000"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="{x:Static res:ResUI.LbUsername}" />
                    <TextBox Text="{Binding Account.Username, Mode=TwoWay}" />
                    <TextBlock Text="{x:Static res:ResUI.LbPassword}" />
                    <TextBox Text="{Binding Account.Password, Mode=TwoWay}" />
                    <TextBlock Text="{x:Static res:ResUI.LbService}" />
                    <ComboBox
                        MinWidth="200"
                        DisplayMemberBinding="{Binding Name}"
                        ItemsSource="{x:Static vm:LoginViewModel.ServiceOptions}"
                        SelectedValue="{Binding Account.Service, Mode=TwoWay}"
                        SelectedValueBinding="{Binding Id}" />
                </StackPanel>
            </Border>
            <Border
                Margin="20"
                Padding="15"
                Background="{DynamicResource SystemRegionBrushLow}"
                BoxShadow="0 4 10 0 #40000000"
                CornerRadius="8"
                IsVisible="{Binding HasLoginMessage}">
                <StackPanel>
                    <TextBlock>
                        <Run FontWeight="Bold" Text="{x:Static res:ResUI.LbMessage}" />
                        <Run Text=": " />
                        <LineBreak />
                        <Run Text="{Binding LoginMessage, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>

</UserControl>
